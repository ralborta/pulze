<title>Instructivo Backoffice PULZE</title>
<style>
body { font-family: Calibri, Arial, sans-serif; font-size: 11pt; line-height: 1.5; margin: 2cm; }
h1 { font-size: 18pt; color: #0d9488; border-bottom: 2px solid #0d9488; padding-bottom: 8px; margin-top: 24px; }
h2 { font-size: 14pt; color: #0f766e; margin-top: 20px; }
h3 { font-size: 12pt; color: #115e59; margin-top: 16px; }
table { border-collapse: collapse; width: 100%; margin: 12px 0; }
th, td { border: 1px solid #94a3b8; padding: 8px 12px; text-align: left; }
th { background-color: #e2e8f0; font-weight: bold; }
tr:nth-child(even) { background-color: #f8fafc; }
ul { margin: 8px 0; padding-left: 24px; }
li { margin: 4px 0; }
p { margin: 8px 0; }
.titulo-doc { font-size: 22pt; text-align: center; margin-bottom: 24px; }
.indice { background-color: #f1f5f9; padding: 16px; margin: 16px 0; }
